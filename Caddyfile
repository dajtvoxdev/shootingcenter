{
    # Global options
    auto_https off
}

shootingcenter.click {
    # Try to resolve backend with retry
    @api {
        path /api/*
    }
    
    handle @api {
        uri strip_prefix /api
        reverse_proxy backend:3001 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }
    
    # Everything else goes to frontend
    reverse_proxy frontend:80 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }
}

www.shootingcenter.click {
    redir https://shootingcenter.click{uri}
}
