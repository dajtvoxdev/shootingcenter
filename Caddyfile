shootingcenter.click {
    # API requests
    route /api/* {
        reverse_proxy backend:3001
    }
    
    # Media files (images, uploads)
    route /media/* {
        reverse_proxy backend:3001
    }
    
    # All other requests go to frontend
    route /* {
        reverse_proxy frontend:80
    }
}

www.shootingcenter.click {
    redir https://shootingcenter.click{uri}
}
